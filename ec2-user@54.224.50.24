version: '3.8'

services:
  rabbitmq:
    image: rabbitmq:4.3.0-management
    container_name: rabbitmq-container
    ports:
      - "5672:5672" # RabbitMQ broker port
      - "15672:15672" # Management UI port
    networks:
      - rabbit-net

  springboot-app:
    build: . # Assumes your Dockerfile is in the same directory
    container_name: springboot-container
    ports:
      - "8080:8080" # Expose your app to your local machine
    depends_on:
      - rabbitmq # Ensures RabbitMQ starts first
    environment:
      - SPRING_RABBITMQ_HOST=rabbitmq # Mentions the service name as host
      - SPRING_RABBITMQ_PORT=5672
    networks:
      - rabbit-net

networks:
  rabbit-net:
    driver: bridge
